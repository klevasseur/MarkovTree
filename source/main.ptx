      <cell>Add two chips to Deuce</cell>
      <cell>0</cell>
      <cell>3</cell>
      <cell>1</cell>
      <cell>4</cell>
      <cell>1</cell>
    </row>
    <row>
      <cell>8</cell>
      <cell>Deuce fires</cell>
      <cell>2</cell>
      <cell>0</cell>
      <cell>2</cell>
      <cell>4</cell>
      <cell>1</cell>
    </row>
    <row>
      <cell>9</cell>
      <cell>Add two chips to Deuce</cell>
