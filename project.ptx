		name="web" 
		format="html" 
		output-dir="web" 
		publication="publication.ptx" />
    <target 
    	source="src/MarkovTree.xml"
    	name="print" 
    	format="pdf" 
    	output-dir="print" 
    	publication="publication.ptx"
    	output-filename="ps-print.pdf" />
